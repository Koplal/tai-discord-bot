# Discord Bot Configuration
# Get these from https://discord.com/developers/applications

DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_GUILD_ID=your_server_id_here

# AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: pin a specific Claude model. Leave unset to auto-discover the newest
# Sonnet via the Models API (falls back to the claude-sonnet-4-6 alias). Set this
# only to force a specific model, e.g. ANTHROPIC_MODEL=claude-opus-4-8.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Linear Configuration
# Get API key from https://linear.app/settings/api
LINEAR_API_KEY=your_linear_api_key_here
# Team UUID for the TAI "Transformational AI" team.
# On the deployed VM this is synced from the GitHub `LINEAR_TEAM_ID` secret on
# every deploy (see .github/workflows/deploy.yml) — set it here for local dev.
LINEAR_TEAM_ID=f7bbac54-652e-4f25-8480-74c3af77f4e8

# Optional: Redis for distributed rate limiting
# REDIS_URL=redis://localhost:6379

# Rollback hotfix flag — set to 'false', '0', 'no', or 'off' to disable image/vision processing.
# Takes effect on restart; case-insensitive. Default: true (vision enabled).
ENABLE_VISION=true
